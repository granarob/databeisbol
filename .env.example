# ================================================================
# .env.example — Variables de entorno requeridas
# Copia este archivo a .env y rellena los valores
# NUNCA subas .env a git
# ================================================================

# ─── Django ──────────────────────────────────────────────────────
# Genera una clave secreta con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-cambia-esta-clave-en-produccion

# True solo en desarrollo local, False en producción
DEBUG=True

# Hosts permitidos (separados por coma)
# En Vercel: .vercel.app,tu-dominio.com
# En Railway: tu-app.railway.app
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Base de Datos ───────────────────────────────────────────────
# Dejar vacío para usar SQLite (desarrollo local)
# En producción: pegar la URL de conexión PostgreSQL
# Formato: postgresql://user:password@host:5432/dbname
# Proveedores recomendados: Supabase, Neon, Railway
DATABASE_URL=

# ─── CORS — Orígenes del frontend ────────────────────────────────
# URL de Vercel en producción, localhost en desarrollo
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── CSRF Trusted Origins (Vercel) ───────────────────────────────
# En producción en Vercel, agregar tu dominio
CSRF_TRUSTED_ORIGINS=https://*.vercel.app,http://localhost:3000,http://127.0.0.1:3000

# ─── HTTPS ───────────────────────────────────────────────────────
# Dejar en True en producción (Vercel/Railway ya manejan HTTPS)
# Poner en False si el proxy upstream no envía HTTPS (raro)
SECURE_SSL_REDIRECT=True

# ─── Vercel-specific ─────────────────────────────────────────────
# Se configura automáticamente en vercel.json, no necesita cambiarse
DJANGO_SETTINGS_MODULE=config.settings

# ─── Supabase Storage ─────────────────────────────────────────────
# URL de tu proyecto Supabase (Settings → API → Project URL)
SUPABASE_URL=https://xxxx.supabase.co
# Service Role Key (Settings → API → service_role) — NUNCA expongas esta key al frontend
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Nombre del bucket público que creaste en Supabase Storage
SUPABASE_BUCKET=databeisbol-assets
